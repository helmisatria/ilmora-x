    "@tanstack/react-start": "^1.167.32",
    "better-auth": "^1.6.9",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "evlog": "^2.16.0",
    "gsap": "^3.15.0",
    "pg-boss": "^12.18.2",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",

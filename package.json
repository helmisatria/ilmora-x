    "jobs:leaderboard": "tsx src/lib/jobs/leaderboard-worker.ts",
    "secret:generate": "node -e \"console.log(require('crypto').randomBytes(32).toString('base64url'))\"",
    "preview": "vite preview",
    "start": "node .output/server/index.mjs"
  },
  "dependencies": {
